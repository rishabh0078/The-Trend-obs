---
const categories = [
  { name: 'Tech & AI', slug: 'tech-ai' },
  { name: 'Memes & Trends', slug: 'memes-trends' },
  { name: 'Creators & Influencers', slug: 'creators' },
  { name: 'Movies & OTT', slug: 'movies-ott' },
];
---

<header id="site-header" class="w-full bg-canvas/95 backdrop-blur-md border-b border-hairline sticky top-0 z-50 transition-all duration-300">
  
  <!-- Top mini-bar: hidden when scrolled -->
  <div id="header-topbar" class="hidden md:flex justify-between items-center px-6 py-2 border-b border-hairline text-xs font-mono tracking-wider text-mute uppercase bg-canvas-soft transition-all duration-300 overflow-hidden">
    <div id="live-date">Loading date...</div>
    <div class="flex items-center space-x-4">
      <span class="font-bold text-highlight-pink animate-pulse">Trending:</span>
      <a href="/posts/future-of-generative-ai" class="hover:text-primary transition-colors">Generative AI 2026</a>
      <span class="text-hairline-strong">|</span>
      <a href="/posts/why-tiktok-creators-are-moving" class="hover:text-primary transition-colors">Creator Economy</a>
    </div>
  </div>

  <!-- Main logo section: shrinks on scroll -->
  <div id="header-logo" class="flex flex-col items-center justify-center py-6 px-4 relative transition-all duration-300">
    <a href="/" class="group">
      <p id="header-wordmark" class="font-sans font-extrabold text-3xl md:text-5xl lg:text-6xl tracking-tighter uppercase text-primary transition-all duration-300 relative select-none text-center">
        The Daily <span class="bg-clip-text text-transparent bg-gradient-to-r from-gradient-dev-start via-violet to-highlight-pink">Drift</span>
      </p>
      <p id="header-tagline" class="text-center font-mono text-[9px] md:text-xs tracking-[0.3em] uppercase text-mute mt-1 group-hover:text-primary transition-all duration-300">
        The Authority on Tech, Culture &amp; Reviews
      </p>
    </a>
  </div>

  <!-- Navigation bar: always visible -->
  <nav class="border-t border-hairline bg-canvas/80 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between h-12">
        
        <!-- Compact logo that appears only when scrolled (desktop) -->
        <a id="compact-logo" href="/" class="hidden font-sans font-black text-base tracking-tighter uppercase text-primary opacity-0 transition-opacity duration-300 pointer-events-none select-none shrink-0 mr-4">
          The Daily <span class="bg-clip-text text-transparent bg-gradient-to-r from-gradient-dev-start to-highlight-pink">Drift</span>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex space-x-1 lg:space-x-2 mx-auto font-sans font-semibold text-sm tracking-wide text-body">
          <li>
            <a href="/" class="px-3 py-1.5 hover:text-primary hover:bg-canvas-soft-2 rounded-md transition-all">Home</a>
          </li>
          {categories.map((cat) => (
            <li>
              <a href={`/${cat.slug}`} class="px-3 py-1.5 hover:text-primary hover:bg-canvas-soft-2 rounded-md transition-all whitespace-nowrap">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile Nav Toggle -->
        <div class="flex md:hidden items-center justify-between w-full">
          <a href="/" class="font-sans font-black text-base tracking-tighter uppercase text-primary">
            The Daily <span class="bg-clip-text text-transparent bg-gradient-to-r from-gradient-dev-start to-highlight-pink">Drift</span>
          </a>
          <button id="mobile-menu-btn" class="p-2 rounded-md text-body hover:text-primary hover:bg-canvas-soft-2 focus:outline-none" aria-label="Toggle Menu">
            <svg class="h-5 w-5" stroke="currentColor" fill="none" viewBox="0 0 24 24">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Nav links -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-hairline bg-canvas px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2 rounded-md font-semibold text-sm text-body hover:text-primary hover:bg-canvas-soft-2">Home</a>
      {categories.map((cat) => (
        <a href={`/${cat.slug}`} class="block px-3 py-2 rounded-md font-semibold text-sm text-body hover:text-primary hover:bg-canvas-soft-2">
          {cat.name}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  // Dynamic client-side date
  const dateEl = document.getElementById('live-date');
  if (dateEl) {
    const options: Intl.DateTimeFormatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    dateEl.textContent = new Date().toLocaleDateString('en-US', options);
  }

  // ── Shrink header on scroll (hysteresis — no flicker) ───────────
  const topbar      = document.getElementById('header-topbar');
  const logoWrap    = document.getElementById('header-logo');
  const compactLogo = document.getElementById('compact-logo');

  const COLLAPSE_AT = 80;   // px — scroll DOWN past this → collapse
  const EXPAND_AT   = 20;   // px — scroll UP back below this → expand

  let isCollapsed = false;
  let ticking = false;

  function collapse() {
    if (isCollapsed) return;          // already collapsed — skip DOM work
    isCollapsed = true;
    topbar?.classList.add('!hidden');
    logoWrap?.classList.add('!py-0', '!max-h-0', '!overflow-hidden', '!opacity-0');
    compactLogo?.classList.remove('hidden', 'opacity-0', 'pointer-events-none');
    compactLogo?.classList.add('opacity-100', 'pointer-events-auto');
  }

  function expand() {
    if (!isCollapsed) return;         // already expanded — skip DOM work
    isCollapsed = false;
    topbar?.classList.remove('!hidden');
    logoWrap?.classList.remove('!py-0', '!max-h-0', '!overflow-hidden', '!opacity-0');
    compactLogo?.classList.add('hidden', 'opacity-0', 'pointer-events-none');
    compactLogo?.classList.remove('opacity-100', 'pointer-events-auto');
  }

  function onScroll() {
    const scrollY = window.scrollY;
    if (scrollY > COLLAPSE_AT) collapse();
    else if (scrollY < EXPAND_AT)  expand();
    // Between EXPAND_AT and COLLAPSE_AT: do nothing → dead zone kills flicker
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(onScroll);
      ticking = true;
    }
  }, { passive: true });

  // ── Mobile menu ──────────────────────────────────────────────────
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu    = document.getElementById('mobile-menu');
  const menuIcon      = document.getElementById('menu-icon');

  if (mobileMenuBtn && mobileMenu && menuIcon) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      const isHidden = mobileMenu.classList.contains('hidden');
      menuIcon.setAttribute('d', isHidden
        ? 'M4 6h16M4 12h16M4 18h16'
        : 'M6 18L18 6M6 6l12 12'
      );
    });
  }
</script>
