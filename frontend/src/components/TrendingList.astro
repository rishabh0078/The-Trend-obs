---
interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      category: 'tech-ai' | 'memes-trends' | 'creators' | 'movies-ott';
      pubDate: Date;
    };
  }>;
}

const { posts } = Astro.props;

const categoryNames = {
  'tech-ai': 'Tech & AI',
  'memes-trends': 'Memes & Trends',
  'creators': 'Creators',
  'movies-ott': 'Movies & OTT',
};
---

<div class="bg-canvas border border-hairline p-6 rounded-lg">
  <div class="flex items-center space-x-2 border-b border-hairline pb-4 mb-6">
    <span class="w-2.5 h-2.5 rounded-full bg-highlight-pink animate-ping"></span>
    <h3 class="font-sans font-black text-lg uppercase tracking-tight text-primary">Trending Now</h3>
  </div>

  <div class="flex flex-col divide-y divide-hairline">
    {posts.slice(0, 5).map((post, index) => (
      <a href={`/posts/${post.id}`} class="group py-4 flex items-start space-x-4 first:pt-0 last:pb-0">
        <!-- Number index -->
        <span class="font-sans font-black text-3xl md:text-4xl text-hairline-strong group-hover:text-highlight-pink transition-colors leading-none">
          {String(index + 1).padStart(2, '0')}
        </span>
        
        <!-- Details -->
        <div class="flex-grow space-y-1">
          <!-- Category -->
          <span class="font-mono text-[9px] font-bold tracking-widest text-mute uppercase">
            {categoryNames[post.data.category]}
          </span>
          <!-- Title -->
          <h4 class="font-sans font-bold text-sm leading-snug text-primary group-hover:text-link-color transition-colors line-clamp-2">
            {post.data.title}
          </h4>
        </div>
      </a>
    ))}
  </div>
</div>
