---
import { calculateReadTime } from '../utils/readTime';

interface Props {
  post: {
    id: string;
    body: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      author: string;
      category: 'tech-ai' | 'memes-trends' | 'creators' | 'movies-ott';
      image: string;
      imageAlt: string;
      featured?: boolean;
    };
  };
}

const { post } = Astro.props;
const readTime = calculateReadTime(post.body);


// Category display mapping
const categoryNames = {
  'tech-ai': 'Tech & AI',
  'memes-trends': 'Memes & Trends',
  'creators': 'Creators',
  'movies-ott': 'Movies & OTT',
};

const categoryColors = {
  'tech-ai': 'text-cyan border-cyan/20 bg-cyan/5',
  'memes-trends': 'text-highlight-pink border-highlight-pink/20 bg-highlight-pink/5',
  'creators': 'text-violet border-violet/20 bg-violet/5',
  'movies-ott': 'text-warning border-warning/20 bg-warning/5',
};

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group flex flex-col space-y-3 bg-canvas border border-hairline p-4 rounded-lg hover:border-hairline-strong transition-all duration-300">
  <!-- Image Container -->
  <a href={`/posts/${post.id}`} class="block overflow-hidden rounded-md relative aspect-video bg-canvas-soft">
    <img
      src={post.data.image}
      alt={post.data.imageAlt}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </a>

  <!-- Content Section -->
  <div class="flex flex-col flex-grow space-y-2">
    <!-- Category & Date Header -->
    <div class="flex items-center justify-between text-[11px] font-mono tracking-wider">
      <span class={`px-2 py-0.5 border rounded-full font-semibold uppercase ${categoryColors[post.data.category]}`}>
        {categoryNames[post.data.category]}
      </span>
      <time datetime={post.data.pubDate.toISOString()} class="text-mute">
        {formattedDate}
      </time>
    </div>

    <!-- Title -->
    <h3 class="font-sans font-bold text-lg leading-snug text-primary group-hover:text-link-color transition-colors line-clamp-2">
      <a href={`/posts/${post.id}`}>
        {post.data.title}
      </a>
    </h3>

    <!-- Description Excerpt -->
    <p class="text-xs text-body leading-relaxed line-clamp-3">
      {post.data.description}
    </p>

    <!-- Meta Footer -->
    <div class="pt-4 border-t border-hairline mt-auto flex items-center justify-between text-[11px] font-mono text-mute">
      <span class="font-semibold text-primary uppercase">{post.data.author}</span>
      <span>{readTime} min read</span>
    </div>
  </div>
</article>
