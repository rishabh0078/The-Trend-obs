---
import Layout from '../layouts/Layout.astro';
import seoConfig from '../data/movie-finder-seo.json';

const { seo, hero, search, examples, howItWorks, faq } = seoConfig;

const SITE = 'https://thedrifthub.com';

// WebApplication schema — tells Google this is a tool/app
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  'name': 'Movie Finder AI',
  'url': `${SITE}/movie-finder`,
  'description': seo.description,
  'keywords': seo.tags,
  'applicationCategory': 'EntertainmentApplication',
  'operatingSystem': 'All',
  'offers': {
    '@type': 'Offer',
    'price': '0',
    'priceCurrency': 'USD'
  },
  'publisher': { '@id': `${SITE}/#organization` },
  'isPartOf': { '@id': `${SITE}/#website` }
};

// FAQPage schema — enables rich FAQ snippets in Google search results
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faq.items.map(item => ({
    '@type': 'Question',
    'name': item.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': item.answer
    }
  }))
};
---

<Layout title={seo.title} description={seo.description} jsonLd={[webAppSchema, faqSchema]} canonicalUrl={`${SITE}/movie-finder`} hideHeader={true}>

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Gradient top bar -->
    <div class="h-1.5 w-full bg-gradient-to-r from-gradient-dev-start via-violet to-highlight-pink"></div>
    
    <!-- Subtle background decoration -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-gradient-to-b from-violet/[0.04] via-highlight-pink/[0.02] to-transparent rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="relative max-w-3xl mx-auto px-6 pt-16 pb-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 mb-8 rounded-full border border-hairline bg-canvas-soft text-xs font-mono tracking-widest uppercase text-mute">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet/60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-violet"></span>
        </span>
        {hero.badge}
      </div>
      
      <!-- Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase leading-[0.95] tracking-tighter text-primary mb-6">
        {hero.h1_line1}<br/>
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-gradient-dev-start via-violet to-highlight-pink">
          {hero.h1_line2}
        </span>
      </h1>
      
      <!-- Subheading -->
      <p class="text-body text-lg md:text-xl max-w-xl mx-auto leading-relaxed mb-2">
        {hero.subtitle}
      </p>
      <p class="text-mute text-sm font-mono tracking-wide">{hero.tagline}</p>
    </div>
  </section>

  <!-- Search Section -->
  <section class="max-w-2xl mx-auto px-6 pb-12">
    <div class="relative group">
      <!-- Animated gradient border glow -->
      <div class="absolute -inset-[1px] bg-gradient-to-r from-gradient-dev-start via-violet to-highlight-pink rounded-2xl opacity-0 group-focus-within:opacity-100 transition-opacity duration-500 blur-[1px]"></div>
      
      <!-- Search Card -->
      <div class="relative bg-canvas border border-hairline rounded-2xl p-6 md:p-8 shadow-sm group-focus-within:shadow-lg transition-shadow duration-500">
        <form id="movie-form">
          <label for="movie-description" class="block text-xs font-mono tracking-widest uppercase text-mute mb-3">
            {search.label}
          </label>
          
          <textarea 
            id="movie-description"
            rows="3" 
            placeholder={search.placeholder}
            class="w-full bg-canvas-soft border border-hairline text-primary placeholder:text-hairline-strong rounded-xl p-4 focus:outline-none focus:border-violet/40 focus:ring-2 focus:ring-violet/10 resize-none text-base md:text-lg transition-all leading-relaxed"
            required
          ></textarea>
          
          <!-- Example chips -->
          <div class="flex flex-wrap gap-2 mt-4 mb-5">
            {examples.map((ex) => (
              <button type="button" class="example-chip px-3 py-1.5 text-xs font-mono text-mute border border-hairline rounded-full hover:border-violet/40 hover:text-violet hover:bg-violet/5 transition-all cursor-pointer" data-text={ex.text}>
                {ex.label}
              </button>
            ))}
          </div>
          
          <!-- Submit Button -->
          <button 
            type="submit" 
            id="search-btn"
            class="w-full bg-primary text-canvas font-sans font-bold text-sm uppercase tracking-widest py-4 rounded-xl hover:bg-ink/80 active:scale-[0.99] transition-all flex items-center justify-center gap-3 disabled:opacity-40 disabled:cursor-not-allowed"
          >
            <span id="btn-text" class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 21-4.3-4.3"></path><circle cx="11" cy="11" r="8"></circle></svg>
              {search.button_text}
            </span>
            <span id="btn-loader" class="hidden items-center gap-2">
              <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              {search.loading_text}
            </span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Results Section (hidden by default) -->
  <section id="result-section" class="max-w-2xl mx-auto px-6 pb-20 hidden">
    <div class="relative">
      <!-- Section label -->
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-hairline"></div>
        <span class="text-xs font-mono tracking-widest uppercase text-mute">AI Result</span>
        <div class="h-px flex-1 bg-hairline"></div>
      </div>
      
      <!-- Result Card -->
      <div id="result-card" class="bg-canvas border border-hairline rounded-2xl overflow-hidden shadow-sm opacity-0 translate-y-4 transition-all duration-700 ease-out">
        <!-- Top accent bar -->
        <div class="h-1 bg-gradient-to-r from-gradient-dev-start via-violet to-highlight-pink"></div>
        
        <div class="p-6 md:p-8">
          <!-- Title Row -->
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-3 mb-1">
            <h2 id="res-title" class="text-2xl md:text-3xl font-black uppercase tracking-tight text-primary leading-tight"></h2>
            <span id="res-year" class="shrink-0 inline-flex items-center px-3 py-1 text-xs font-mono font-bold tracking-wider bg-canvas-soft border border-hairline rounded-full text-mute"></span>
          </div>
          
          <!-- Genre tag -->
          <p id="res-genre" class="text-sm font-mono text-violet mb-6"></p>
          
          <!-- Divider -->
          <div class="h-px bg-hairline mb-6"></div>
          
          <!-- Description -->
          <p id="res-desc" class="text-body text-base md:text-lg leading-relaxed mb-6"></p>
          
          <!-- Director -->
          <div class="flex items-center gap-2 text-sm font-mono">
            <span class="text-mute uppercase tracking-wider">Director</span>
            <span class="text-hairline-strong">—</span>
            <span id="res-director" class="text-primary font-semibold"></span>
          </div>
        </div>
      </div>
      
      <!-- Search Again Button -->
      <div class="text-center mt-6">
        <button id="search-again-btn" class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-mono tracking-widest uppercase text-mute border border-hairline rounded-full hover:border-violet/40 hover:text-violet hover:bg-violet/5 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path><path d="M16 16h5v5"></path></svg>
          Search Again
        </button>
      </div>
    </div>
  </section>
  
  <!-- Error State -->
  <div id="error-container" class="max-w-2xl mx-auto px-6 pb-12 hidden">
    <div class="bg-error/5 border border-error/15 text-error p-4 rounded-xl text-sm font-mono text-center">
      <span id="error-message"></span>
    </div>
  </div>

  <!-- How It Works Section -->
  <section class="max-w-4xl mx-auto px-6 py-20 border-t border-hairline">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-primary mb-3">{howItWorks.heading}</h2>
      <p class="text-mute text-sm font-mono tracking-wide">{howItWorks.subheading}</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      {howItWorks.steps.map((step) => (
        <div class="text-center group">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-canvas-soft border border-hairline flex items-center justify-center group-hover:border-violet/30 group-hover:bg-violet/5 transition-all duration-300">
            <span class="text-2xl">{step.emoji}</span>
          </div>
          <div class="text-xs font-mono tracking-widest text-violet uppercase mb-2">{step.step}</div>
          <h3 class="font-bold text-primary mb-2">{step.title}</h3>
          <p class="text-sm text-body leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ Section for SEO -->
  <section class="max-w-3xl mx-auto px-6 py-16 border-t border-hairline">
    <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-primary mb-10 text-center">{faq.heading}</h2>
    
    <div class="space-y-0 divide-y divide-hairline">
      {faq.items.map((item) => (
        <details class="group py-5">
          <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-primary hover:text-violet transition-colors">
            <span>{item.question}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-mute group-open:rotate-180 transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
          </summary>
          <p class="mt-3 text-body text-sm leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('movie-form');
  const input = document.getElementById('movie-description') as HTMLTextAreaElement;
  const btn = document.getElementById('search-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnLoader = document.getElementById('btn-loader');
  
  const resultSection = document.getElementById('result-section');
  const resultCard = document.getElementById('result-card');
  const errorContainer = document.getElementById('error-container');
  const errorMessage = document.getElementById('error-message');
  const searchAgainBtn = document.getElementById('search-again-btn');
  
  const resTitle = document.getElementById('res-title');
  const resYear = document.getElementById('res-year');
  const resGenre = document.getElementById('res-genre');
  const resDesc = document.getElementById('res-desc');
  const resDirector = document.getElementById('res-director');

  // Example chip click handler
  document.querySelectorAll('.example-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const text = (chip as HTMLElement).dataset.text || '';
      input.value = text;
      input.focus();
    });
  });

  // Search Again button
  searchAgainBtn?.addEventListener('click', () => {
    resultSection?.classList.add('hidden');
    resultCard?.classList.remove('opacity-100', 'translate-y-0');
    resultCard?.classList.add('opacity-0', 'translate-y-4');
    input.value = '';
    input.focus();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const description = input.value.trim();
    if (!description) return;

    // Set loading state
    btn.disabled = true;
    btnText?.classList.add('hidden');
    btnLoader?.classList.remove('hidden');
    btnLoader?.classList.add('flex');
    resultSection?.classList.add('hidden');
    resultCard?.classList.remove('opacity-100', 'translate-y-0');
    resultCard?.classList.add('opacity-0', 'translate-y-4');
    errorContainer?.classList.add('hidden');

    try {
      const response = await fetch('/api/find-movie', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ description })
      });

      const data = await response.json();

      if (!response.ok || data.error) {
        throw new Error(data.error || 'Failed to identify the movie.');
      }

      // Populate result
      if (resTitle) resTitle.textContent = data.title || 'Unknown Title';
      if (resYear) resYear.textContent = data.year || '—';
      if (resGenre) resGenre.textContent = data.genre || '';
      if (resDesc) resDesc.textContent = data.description || '';
      if (resDirector) resDirector.textContent = data.director || 'Unknown';

      // Reveal result with animation
      resultSection?.classList.remove('hidden');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          resultCard?.classList.remove('opacity-0', 'translate-y-4');
          resultCard?.classList.add('opacity-100', 'translate-y-0');
        });
      });

      // Smooth scroll to result
      setTimeout(() => {
        resultSection?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 300);

    } catch (error: any) {
      if (errorMessage) errorMessage.textContent = error.message;
      errorContainer?.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btnLoader?.classList.add('hidden');
      btnLoader?.classList.remove('flex');
      btnText?.classList.remove('hidden');
    }
  });
</script>
