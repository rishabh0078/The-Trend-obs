---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import TrendingList from '../components/TrendingList.astro';

export async function getStaticPaths() {
  const categories = ['tech-ai', 'memes-trends', 'creators', 'movies-ott'];
  return categories.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;

// Fetch blog posts in this category
const allPosts = await getCollection('blog');
const categoryPosts = allPosts
  .filter((post) => post.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Trending posts for sidebar
const trendingPosts = allPosts
  .filter((post) => post.data.trending)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// Category branding metadata
const categoryMetadata = {
  'tech-ai': {
    name: 'Tech & AI',
    description: 'Expert analysis and breaking news on artificial intelligence, spatial computing, hardware, and the future of technology.',
    colorClass: 'border-cyan text-cyan bg-cyan/5',
    accentColor: 'from-gradient-dev-start to-gradient-dev-end',
  },
  'memes-trends': {
    name: 'Memes & Trends',
    description: 'Deconstructing the internet trends, memes, and viral movements shaping global culture and digital communication.',
    colorClass: 'border-highlight-pink text-highlight-pink bg-highlight-pink/5',
    accentColor: 'from-gradient-prev-start to-gradient-prev-end',
  },
  'creators': {
    name: 'Creators & Influencers',
    description: 'In-depth coverage of the creator economy, digital platforms, influencer culture, and talent migrations.',
    colorClass: 'border-violet text-violet bg-violet/5',
    accentColor: 'from-violet to-violet-deep',
  },
  'movies-ott': {
    name: 'Movies & OTT',
    description: 'Unbiased reviews, production updates, and analysis of cinematic releases and streaming television shows.',
    colorClass: 'border-warning text-warning bg-warning/5',
    accentColor: 'from-gradient-ship-start to-gradient-ship-end',
  },
};

const meta = categoryMetadata[category as keyof typeof categoryMetadata] || {
  name: 'Articles',
  description: 'The latest stories from The Daily Drift.',
  colorClass: 'border-primary text-primary bg-primary/5',
  accentColor: 'from-primary to-[#333333]',
};

// Collection Schema for Google SEO
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `https://thedailydrift.com/${category}/#collection`,
  'url': `https://thedailydrift.com/${category}`,
  'name': `${meta.name} Articles | The Daily Drift`,
  'description': meta.description,
  'isPartOf': {
    '@id': 'https://thedailydrift.com/#website'
  },
  'about': {
    '@type': 'Thing',
    'name': meta.name
  }
};
---

<Layout
  title={`${meta.name} | The Daily Drift`}
  description={meta.description}
  jsonLd={collectionSchema}
>
  <div class="max-w-6xl mx-auto px-6 py-8">
    
    <!-- Category Header Banner -->
    <header class="border border-hairline p-8 rounded-lg mb-10 relative overflow-hidden bg-canvas-soft-2">
      <!-- Decorative gradient splash -->
      <div class={`absolute right-0 top-0 w-48 h-48 bg-gradient-to-br ${meta.accentColor} opacity-5 blur-2xl rounded-full`}></div>
      
      <div class="relative space-y-3 max-w-2xl">
        <span class={`inline-block px-3 py-1 text-xs font-mono font-bold tracking-widest uppercase border rounded-full ${meta.colorClass}`}>
          Stream Category
        </span>
        <h2 class="font-sans font-black text-3xl md:text-5xl uppercase tracking-tighter text-primary">
          {meta.name}
        </h2>
        <p class="text-sm md:text-base text-body leading-relaxed">
          {meta.description}
        </p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Main Content Grid -->
      <div class="lg:col-span-2">
        {categoryPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {categoryPosts.map((post) => (
              <ArticleCard post={post} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16 border border-dashed border-hairline rounded-lg">
            <p class="text-mute font-mono text-sm">No stories published in this stream yet.</p>
          </div>
        )}
      </div>

      <!-- Sidebar Column -->
      <aside class="space-y-8 lg:border-l lg:border-hairline lg:pl-8">
        <TrendingList posts={trendingPosts} />
      </aside>

    </div>
  </div>
</Layout>
